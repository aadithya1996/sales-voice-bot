# ===========================================
# Pipeline Pilot — AI Sales Assistant
# Environment Variables
# ===========================================

# HubSpot CRM
# Create a Private App: Settings → Integrations → Private Apps
# Required scopes: crm.objects.contacts.read/write, crm.objects.deals.read/write, crm.schemas.deals.read, crm.objects.owners.read
HUBSPOT_ACCESS_TOKEN=your_hubspot_private_app_token_here

# Retell AI
# Get from: dashboard.retellai.com → Settings → API Keys
RETELL_API_KEY=your_retell_api_key_here

# Retell Agent ID (auto-created on first run, or set manually)
RETELL_AGENT_ID=your_retell_agent_id_here

# OpenAI
# Get from: platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Server Config
PORT=3000
WS_PORT=8080

# WebSocket URL for Retell callback
# In production, set this to your Railway WS service domain:
# Example: wss://sales-voice-bot-ws.up.railway.app/llm-websocket
# In local dev, use your ngrok URL
RETELL_WS_URL=your_ws_server_public_url_here

# Internal Bridge Secret (for ws-server.js → Next.js event forwarding)
BRIDGE_SECRET=your_random_secret_here

# Firebase (optional, for deployment)
FIREBASE_PROJECT_ID=your-project-id
